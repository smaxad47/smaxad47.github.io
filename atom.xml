ne">#获取链接地址和标题</span><br><span class="line">#linkspan = rowX.find(class_=&quot;topic&quot;)</span><br><span class="line">#link = linkspan.get(&apos;href&apos;)</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">#[s.extract() for s in linkspan(&apos;span&apos;)]</span><br><span class="line"></span><br><span class="line">#title = linkspan.find_all(&quot;a&quot;)</span><br><span class="line">#del linkspan[&apos;class&apos;]</span><br><span class="line">#del linkspan[&apos;href&apos;]</span><br><span class="line">#del linkspan[&apos;id&apos;]</span><br><span class="line">#title = linkspan.text</span><br><span class="line">#print (title)</span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line">for rowX in soap.find_all(class_=&quot;row1 topicrow&quot;):</span><br><span class="line">    time = rowX.find(class_=&quot;silver postdate&quot;)</span><br><span class="line">    time = time.get(&apos;title&apos;)</span><br><span class="line">    linkspan = rowX.find(class_=&quot;topic&quot;)</span><br><span class="line">    [s.extract() for s in linkspan(&apos;span&apos;)]</span><br><span class="line">    link = linkspan.get(&apos;href&apos;)</span><br><span class="line">    del linkspan[&apos;class&apos;]</span><br><span class="line">    del linkspan[&apos;href&apos;]</span><br><span class="line">    del linkspan[&apos;id&apos;]</span><br><span class="line">    title = linkspan.text</span><br><span class="line">    print(time,&quot; &quot;,title,&quot; &quot;,link,&quot; &quot;,&apos;\n&apos;)</span><br><span class="line"></span><br><span class="line">for rowX in soap.find_all(class_=&quot;row2 topicrow&quot;):</span><br><span class="line">    time = rowX.find(class_=&quot;silver postdate&quot;)</span><br><span class="line">    time = time.get(&apos;title&apos;)</span><br><span class="line">    linkspan = rowX.find(class_=&quot;topic&quot;)</span><br>